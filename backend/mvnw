# The ASF licenses this file to You under the Apache License, Version 2.0.
# ----------------------------------------------------------------------------

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="`which java`"
  if [ -n "$javaExecutable" ] && ! [ "`ls -l \"$javaExecutable\" | grep \"ls: cannot\"`" ]; then
    JAVA_HOME="`dirname \"$javaExecutable\"`/.."
    export JAVA_HOME
  fi
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR="$( cd "$(dirname "$0")" && pwd )"
  export MAVEN_PROJECTBASEDIR
fi

MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
  WRAPPER_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')
fi

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  if command -v mvn > /dev/null 2>&1; then
    exec mvn "$@"
  else
    echo "Maven not found. Please install Maven or run: mvn -N io.takari:maven:wrapper"
    exit 1
  fi
fi

exec "$JAVA_HOME/bin/java" \
  -classpath "$MAVEN_WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"